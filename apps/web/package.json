{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x",
    "pnpm": "9.x"
  },
  "scripts": {
    "check:runtime": "node ../../scripts/check-runtime.mjs",
    "dev": "pnpm check:runtime && next dev -p 3000",
    "build": "pnpm check:runtime && next build",
    "start": "pnpm check:runtime && next start -p 3000",
    "lint": "pnpm check:runtime && next lint",
    "typecheck": "pnpm check:runtime && tsc --noEmit",
    "test": "pnpm run typecheck"
  },
  "dependencies": {
    "next": "15.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@eslint/eslintrc": "^3.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.2.1",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "typescript": "^5"
  }
}

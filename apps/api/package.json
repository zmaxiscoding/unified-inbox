{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x",
    "pnpm": "9.x"
  },
  "scripts": {
    "check:runtime": "node ../../scripts/check-runtime.mjs",
    "dev": "pnpm check:runtime && nest start --watch",
    "build": "pnpm check:runtime && nest build",
    "start": "pnpm check:runtime && node dist/src/main.js",
    "lint": "pnpm check:runtime && eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "pnpm check:runtime && jest",
    "test:watch": "pnpm check:runtime && jest --watch",
    "test:cov": "pnpm check:runtime && jest --coverage",
    "prisma:generate": "pnpm check:runtime && prisma generate",
    "db:migrate": "pnpm check:runtime && prisma migrate dev",
    "db:seed": "pnpm check:runtime && prisma db seed",
    "db:reset": "pnpm check:runtime && prisma migrate reset --force"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.63.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "reflect-metadata": "^0.2.0",
    "resend": "^6.9.4",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.2",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.5.0",
    "prisma": "^6.0.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "setupFiles": [
      "<rootDir>/test/setup-env.ts"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}

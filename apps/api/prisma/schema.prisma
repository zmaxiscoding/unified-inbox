generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenant ────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       Membership[]
  channels      Channel[]
  channelAccounts ChannelAccount[]
  conversations Conversation[]
  tags          Tag[]
  invitations   Invitation[]
  auditLogs     AuditLog[]
  rawWebhookEvents RawWebhookEvent[]

  @@map("organizations")
}

// ─── Users & Roles ───────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships Membership[]
  messages    Message[]
  notes       Note[]
  auditLogs   AuditLog[]

  @@map("users")
}

enum Role {
  OWNER
  AGENT
}

model Membership {
  id             String       @id @default(cuid())
  role           Role         @default(AGENT)
  organizationId String
  userId         String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization          Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedConversations Conversation[]
  createdInvitations    Invitation[]

  @@unique([organizationId, userId])
  // Required for the composite FK from Conversation (enforces cross-tenant safety at DB level)
  @@unique([id, organizationId])
  @@map("memberships")
}

// ─── Channels ────────────────────────────────────────────

enum ChannelType {
  WHATSAPP
  INSTAGRAM
}

model Channel {
  id             String      @id @default(cuid())
  type           ChannelType
  name           String
  externalId     String?
  credentials    Json?
  organizationId String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([organizationId, type, externalId])
  @@map("channels")
}

// ─── Conversations ───────────────────────────────────────

enum ConversationStatus {
  OPEN
  RESOLVED
  SNOOZED
}

model Conversation {
  id                   String             @id @default(cuid())
  status               ConversationStatus @default(OPEN)
  contactName          String
  contactPhone         String?
  contactAvatar        String?
  externalThreadId     String?
  lastMessageAt        DateTime?
  lastMessageText      String?
  isUnread             Boolean            @default(true)
  organizationId       String
  channelId            String
  // Composite FK to Membership(id, organizationId): DB enforces assignee is in the same org
  assignedMembershipId String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channel            Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  // onDelete: Restrict — app must unassign before removing a member
  // (SetNull unsafe on composite FK where organizationId is NOT NULL)
  assignedMembership Membership?  @relation(fields: [assignedMembershipId, organizationId], references: [id, organizationId], onDelete: Restrict)
  messages           Message[]
  notes              Note[]
  tags               ConversationTag[]

  @@index([organizationId, status])
  @@index([organizationId, lastMessageAt(sort: Desc)])
  @@index([assignedMembershipId])
  @@unique([organizationId, channelId, externalThreadId])
  @@map("conversations")
}

// ─── Messages ────────────────────────────────────────────

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum OutboundMessageDeliveryStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  READ
  FAILED
}

model Message {
  id                      String                         @id @default(cuid())
  direction               MessageDirection
  body                    String
  providerMessageId       String?                        @unique
  deliveryStatus          OutboundMessageDeliveryStatus?
  deliveryStatusUpdatedAt DateTime?
  providerError           String?
  sentAt                  DateTime?
  deliveredAt             DateTime?
  readAt                  DateTime?
  failedAt                DateTime?
  conversationId          String
  senderId                String?
  createdAt               DateTime                       @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?        @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([direction, deliveryStatus, createdAt(sort: Desc)])
  @@map("messages")
}

// ─── Notes (internal) ────────────────────────────────────

model Note {
  id             String   @id @default(cuid())
  body           String
  conversationId String
  authorId       String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author       User         @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("notes")
}

// ─── Tags ────────────────────────────────────────────────

model Tag {
  id             String   @id @default(cuid())
  name           String
  organizationId String
  createdAt      DateTime @default(now())

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations ConversationTag[]

  @@unique([organizationId, name])
  @@map("tags")
}

model ConversationTag {
  conversationId String
  tagId          String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tag          Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([conversationId, tagId])
  @@map("conversation_tags")
}

// ─── Invitations ──────────────────────────────────────

model Invitation {
  id                    String    @id @default(cuid())
  email                 String
  role                  Role      @default(AGENT)
  tokenHash             String    @unique
  expiresAt             DateTime
  acceptedAt            DateTime?
  revokedAt             DateTime?
  organizationId        String
  createdByMembershipId String
  createdAt             DateTime  @default(now())

  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByMembership Membership   @relation(fields: [createdByMembershipId], references: [id], onDelete: Cascade)

  @@index([organizationId, email])
  // Enforced in SQL migration: unique pending invite per (organizationId, email)
  // where acceptedAt IS NULL and revokedAt IS NULL.
  @@map("invitations")
}

// ─── Audit Log ───────────────────────────────────────────

model AuditLog {
  id             String   @id @default(cuid())
  action         String
  targetId       String?
  metadata       Json?
  organizationId String
  actorId        String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User         @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([organizationId, action])
  @@map("audit_logs")
}

// ─── Channel Accounts ────────────────────────────────────

model ChannelAccount {
  id                String      @id @default(cuid())
  provider          ChannelType
  externalAccountId String
  displayPhoneNumber String?
  wabaId            String?
  // Encrypted at rest via CryptoService when CHANNEL_TOKEN_SECRET is set.
  accessToken       String
  organizationId    String
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider, externalAccountId])
  @@unique([provider, externalAccountId])
  @@index([provider, externalAccountId])
  @@map("channel_accounts")
}

enum WebhookProcessingStatus {
  PENDING
  PROCESSED
  FAILED
}

model RawWebhookEvent {
  id                String                  @id @default(cuid())
  provider          ChannelType
  providerMessageId String
  externalAccountId String
  payload           Json
  processingStatus  WebhookProcessingStatus @default(PENDING)
  processedAt       DateTime?
  error             String?
  organizationId    String
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([provider, providerMessageId])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([provider, externalAccountId, createdAt(sort: Desc)])
  @@map("raw_webhook_events")
}

PORT=3001
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/unified_inbox?schema=public"

# Required in production for BullMQ processing and Redis-backed realtime fanout.
# Local dev: docker compose provides Redis on localhost:6379.
REDIS_URL="redis://localhost:6379"

SESSION_SECRET="change-me-in-production"
APP_URL="http://localhost:3000"

# Auth email transport:
# - `disabled`: request endpoints stay generic/no-op
# - `outbox`: write preview files locally
# - `resend`: deliver through Resend
# `AUTH_EMAIL_VERIFICATION_MODE=login` requires `outbox` or `resend`.
# If unset: development defaults to `outbox`, test/production defaults to `disabled`.
AUTH_EMAIL_TRANSPORT="outbox"
AUTH_EMAIL_FROM="Unified Inbox <no-reply@example.test>"
AUTH_EMAIL_OUTBOX_DIR=".auth-email-outbox"
# `login` blocks new sign-ins for unverified users and is incompatible with
# `AUTH_EMAIL_TRANSPORT=disabled` because users must still be able to request verification mail.
AUTH_EMAIL_VERIFICATION_MODE="soft"
# `disabled` is safe for local no-op flows, but production verification / recovery
# flows should use `outbox` or `resend`.

# Required when AUTH_EMAIL_TRANSPORT=resend
RESEND_API_KEY=""

# Explicit cold-start recovery secret for legacy tenants with no password-backed OWNER.
# Leave unset unless you need the one-time POST /auth/recover-owner path.
AUTH_RECOVERY_SECRET=""

WHATSAPP_VERIFY_TOKEN="change-me-whatsapp-verify-token"
WHATSAPP_APP_SECRET="change-me-whatsapp-app-secret"
INSTAGRAM_VERIFY_TOKEN="change-me-instagram-verify-token"
INSTAGRAM_APP_SECRET="change-me-instagram-app-secret"
# Optional override for provider API versions; defaults to v21.0 in adapters.
WHATSAPP_GRAPH_API_VERSION="v21.0"
INSTAGRAM_GRAPH_API_VERSION="v21.0"

# Encryption key for channel access tokens at rest. At least 16 characters.
# If unset, tokens are stored in plaintext (dev-only; production must set this).
CHANNEL_TOKEN_SECRET="change-me-at-least-16-chars"

# When true AND REDIS_URL is unset, webhooks are processed inline and realtime
# fanout falls back to same-process delivery only (dev only).
# Production always requires REDIS_URL regardless of this flag.
ENABLE_DEV_ENDPOINTS=false
